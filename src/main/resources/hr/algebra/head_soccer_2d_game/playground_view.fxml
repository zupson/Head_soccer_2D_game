<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="700.0" maxWidth="1000.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.algebra.head_soccer_2d_game.client.controller.ui.PlaygroundController">
    <top>
        <AnchorPane prefWidth="1000.0" BorderPane.alignment="CENTER">

            <Label fx:id="lbRightPlayerScore" alignment="CENTER" layoutX="414.0" layoutY="36.0" prefHeight="50.0" prefWidth="32.0" text="0" textAlignment="CENTER" textFill="#141414">
                <font>
                    <Font name="System Bold" size="36.0" />
                </font>
            </Label>
            <Label fx:id="lbLeftPlayerScore" alignment="CENTER" layoutX="557.0" layoutY="36.0" prefHeight="50.0" prefWidth="29.0" text="0" textFill="#141414">
                <font>
                    <Font name="System Bold" size="36.0" />
                </font>
            </Label>
            <Label layoutX="484.0" layoutY="45.0" text="VS">
                <font>
                    <Font size="24.0" />
                </font>
            </Label>
            <Label fx:id="lbTimer" contentDisplay="CENTER" layoutX="487.0" layoutY="14.0" text="60">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>
            <Button fx:id="btnPause" layoutX="792.0" layoutY="27.0" mnemonicParsing="false" onAction="#onPauseClicked" prefHeight="45.0" prefWidth="79.0" text="Pause" />
            <Button fx:id="btnResume" layoutX="892.0" layoutY="26.0" mnemonicParsing="false" onAction="#onResumeClicked" prefHeight="46.0" prefWidth="84.0" text="Resume" visible="false" />
            <Button fx:id="btnSent" layoutX="178.0" layoutY="15.0" mnemonicParsing="false" onAction="#sendChatMessage" prefHeight="25.0" prefWidth="46.0" text="Send " />
            <TextField fx:id="tfChat" layoutX="14.0" layoutY="15.0" prefHeight="22.0" prefWidth="150.0" promptText="Write message" />
            <TextArea fx:id="taChat" layoutX="14.0" layoutY="50.0" prefHeight="71.0" prefWidth="149.0" />
         <Label fx:id="lbLeftPlayer" layoutX="391.0" layoutY="15.0" prefHeight="22.0" prefWidth="76.0">
            <font>
               <Font size="14.0" />
            </font>
         </Label>
         <Label fx:id="lbRightPlayer" layoutX="547.0" layoutY="15.0" prefHeight="22.0" prefWidth="66.0">
            <font>
               <Font size="14.0" />
            </font>
         </Label>
        </AnchorPane>
    </top>

    <center>
        <Canvas fx:id="gameCanvas" height="600.0" width="1000.0" />
    </center>

</BorderPane>
